    const handleDelete = async () => {
        setDeleting(true);
        try {
            await flashcardService.deleteFlashcardSet(flashcardSet._id);
            toast.success('Flashcard set deleted');
            onDelete(flashcardSet._id);
        } catch {
            toast.error('Failed to delete');
        } finally {
            setDeleting(false);
            setShowConfirm(false);
        }
